{
    "name": "otp-telegram-bot",
    "version": "1.0.0",
    "description": "Bot Jasa OTP Telegram dengan Node.js, Telegraf, PostgreSQL, Redis, dan Midtrans",
    "main": "src/app.js",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "start:cluster": "pm2 start ecosystem.config.js",
        "stop": "pm2 stop ecosystem.config.js",
        "restart": "pm2 restart ecosystem.config.js",
        "logs": "pm2 logs",
        "monitor": "pm2 monit",
        "db:migrate": "node -e \"require('fs').readFileSync('./src/database/migrations/init.sql', 'utf8').split(';').forEach(q => q.trim() && console.log(q))\" | psql $DATABASE_URL",
        "db:backup": "pg_dump $DATABASE_URL > backups/backup_$(date +%Y%m%d_%H%M%S).sql",
        "test": "jest --coverage",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "security:check": "npm audit",
        "security:fix": "npm audit fix"
    },
    "keywords": [
        "telegram",
        "bot",
        "otp",
        "nodejs",
        "telegraf",
        "postgresql",
        "redis",
        "midtrans"
    ],
    "author": "Your Name",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "dependencies": {
        "axios": "^1.15.2",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "crypto-js": "^4.2.0",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "midtrans-client": "^1.4.3",
        "moment-timezone": "^0.5.43",
        "node-cron": "^3.0.3",
        "numeral": "^2.0.6",
        "pg": "^8.20.0",
        "pg-pool": "^3.6.1",
        "redis": "^5.12.1",
        "telegraf": "^4.16.3",
        "uuid": "^9.0.1",
        "validator": "^13.11.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^4.7.1"
    },
    "devDependencies": {
        "eslint": "^8.55.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "supertest": "^6.3.3"
    },
    "nodemonConfig": {
        "watch": [
            "src"
        ],
        "ext": "js,json",
        "ignore": [
            "logs/*",
            "backups/*",
            "node_modules/*"
        ],
        "delay": 1000
    },
    "jest": {
        "testEnvironment": "node",
        "coverageDirectory": "./coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/app.js",
            "!src/server.js"
        ]
    }
}
