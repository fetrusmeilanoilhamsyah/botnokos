# ============================================================
# BOT JASA OTP TELEGRAM - ENV EXAMPLE
# ============================================================

# APPLICATION
NODE_ENV=production
PORT=3000
TZ=Asia/Jakarta

# TELEGRAM BOT
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here
BOT_MODE=polling
SUPPORT_TELEGRAM=@your_username

# DATABASE (POSTGRESQL)
DATABASE_URL=postgresql://botuser:BotPass123!@localhost:5432/otp_bot

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# MIDTRANS PAYMENT
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_SERVER_KEY=your_server_key_here
MIDTRANS_CLIENT_KEY=your_client_key_here
MIDTRANS_NOTIFICATION_URL=https://yourdomain.com/webhook/midtrans

# OTP SERVICE
OTP_API_KEY=your_jasaotp_api_key_here
OTP_AUTO_CANCEL_TIMEOUT=300
OTP_MARGIN_FLAT=1000

# PERFORMANCE (VPS 1GB RAM)
NODE_OPTIONS=--max-old-space-size=768
