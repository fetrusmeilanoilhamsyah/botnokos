# ============================================================
# BOT JASA OTP TELEGRAM - ENVIRONMENT CONFIGURATION
# ============================================================
# PENTING: 
# 1. Copy file ini menjadi .env
# 2. Isi semua value dengan credentials yang valid
# 3. JANGAN commit file .env ke repository!
# ============================================================

# ============================================================
# APPLICATION SETTINGS
# ============================================================
NODE_ENV=production
APP_NAME=OTP_Telegram_Bot
APP_VERSION=1.0.0
PORT=3000
HOST=0.0.0.0

# Timezone
TZ=Asia/Jakarta

# ============================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# Webhook Configuration (jika menggunakan webhook, bukan polling)
# Kosongkan jika menggunakan polling mode
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret_key_here

# Bot Owner/Admin Telegram ID (untuk notifikasi admin)
ADMIN_TELEGRAM_ID=123456789

# Bot Mode: 'polling' atau 'webhook'
BOT_MODE=polling

# ============================================================
# POSTGRESQL DATABASE CONFIGURATION
# ============================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://otp_bot_user:your_strong_password@localhost:5432/otp_bot_db

# Alternative: Individual parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=otp_bot_db
DB_USER=otp_bot_user
DB_PASSWORD=your_strong_password

# Connection Pool Settings (untuk VPS 1GB RAM - keep it minimal)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# SSL Mode (production: require, development: disable)
DB_SSL_MODE=disable

# ============================================================
# REDIS CONFIGURATION
# ============================================================
# Untuk session management, caching, dan rate limiting
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis Connection Options
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# Session Configuration
SESSION_TTL=3600
SESSION_PREFIX=otp_bot:session:

# Cache TTL (dalam detik)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# ============================================================
# MIDTRANS PAYMENT GATEWAY
# ============================================================
# Dapatkan dari Midtrans Dashboard (https://dashboard.midtrans.com)

# Server Key & Client Key
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx

# Merchant ID
MIDTRANS_MERCHANT_ID=M001234

# Environment: 'sandbox' atau 'production'
MIDTRANS_ENVIRONMENT=sandbox

# Snap API URL (auto-set based on environment)
# Sandbox: https://app.sandbox.midtrans.com/snap/v1/transactions
# Production: https://app.midtrans.com/snap/v1/transactions

# Payment Notification URL (webhook dari Midtrans)
MIDTRANS_NOTIFICATION_URL=https://yourdomain.com/webhook/midtrans

# Minimum & Maximum Topup Amount (in IDR)
MIN_TOPUP_AMOUNT=10000
MAX_TOPUP_AMOUNT=10000000

# Admin Fee (0 = no fee)
TOPUP_ADMIN_FEE=0

# ============================================================
# OTP SERVICE API CONFIGURATION
# ============================================================
# Ganti dengan kredensial dari provider OTP service Anda
# Contoh: SMS-Activate, GetSMS.online, SMSHUB, dll

# API Base URL
OTP_API_BASE_URL=https://api.yourprovider.com

# API Key
OTP_API_KEY=your_otp_api_key_here

# API Secret (jika diperlukan)
OTP_API_SECRET=your_otp_api_secret_here

# API Request Timeout (milliseconds)
OTP_API_TIMEOUT=30000

# Auto Cancel Timeout (jika SMS tidak diterima, dalam detik)
OTP_AUTO_CANCEL_TIMEOUT=300

# Retry Configuration
OTP_MAX_RETRIES=3
OTP_RETRY_DELAY=2000

# ============================================================
# SECURITY CONFIGURATION
# ============================================================

# JWT Secret (untuk auth token jika diperlukan)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Encryption Key (untuk encrypt sensitive data)
ENCRYPTION_KEY=your_32_character_encryption_key_here!

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=30

# Daily Order Limit per User
DAILY_ORDER_LIMIT=50

# Maximum Failed Login Attempts
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=1800

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log Level: 'error', 'warn', 'info', 'http', 'debug'
LOG_LEVEL=info

# Log Directory
LOG_DIR=./logs

# Log File Rotation (in MB)
LOG_MAX_SIZE=10

# Max Log Files to Keep
LOG_MAX_FILES=14

# Log to Console
LOG_CONSOLE=true

# Log to File
LOG_FILE=true

# ============================================================
# ERROR TRACKING (Optional - Sentry, etc)
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn-here
# SENTRY_ENVIRONMENT=production

# ============================================================
# NOTIFICATION SETTINGS
# ============================================================

# Send notification to admin for important events
ADMIN_NOTIFICATIONS=true

# Notification Types (comma separated)
# Options: new_user, large_topup, suspicious_activity, system_error
NOTIFICATION_TYPES=large_topup,suspicious_activity,system_error

# Large Topup Threshold (notify admin if topup >= this amount)
LARGE_TOPUP_THRESHOLD=1000000

# ============================================================
# FEATURE FLAGS
# ============================================================

# Enable/Disable Features
FEATURE_REFERRAL_SYSTEM=false
FEATURE_AUTO_REFUND=true
FEATURE_PROMO_CODES=false
FEATURE_MAINTENANCE_MODE=false

# Maintenance Message
MAINTENANCE_MESSAGE=Sistem sedang dalam maintenance. Silakan coba lagi nanti.

# ============================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================

# Memory Limit (in MB) - untuk VPS 1GB RAM
NODE_OPTIONS=--max-old-space-size=768

# Enable Cluster Mode (number of workers, 0 = auto based on CPU cores)
CLUSTER_WORKERS=0

# Enable Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30000

# Keep Alive Timeout
KEEP_ALIVE_TIMEOUT=65000

# Headers Timeout
HEADERS_TIMEOUT=66000

# ============================================================
# BACKUP & RECOVERY
# ============================================================

# Auto Backup Database (cron schedule: minute hour day month weekday)
AUTO_BACKUP_SCHEDULE=0 2 * * *

# Backup Directory
BACKUP_DIR=./backups

# Keep Backup for N days
BACKUP_RETENTION_DAYS=30

# ============================================================
# DEVELOPMENT SETTINGS (hanya untuk development)
# ============================================================

# Enable Debug Mode
DEBUG=false

# Mock Payment (bypass Midtrans di development)
MOCK_PAYMENT=false

# Mock OTP Service (bypass OTP API di development)
MOCK_OTP_SERVICE=false

# Test Telegram ID (untuk testing tanpa mengganggu production)
TEST_TELEGRAM_ID=987654321

# ============================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================

# Google Analytics Tracking ID
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# Enable Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=false

# ============================================================
# CRON JOBS SCHEDULE
# ============================================================

# Clean expired transactions (daily at 3 AM)
CRON_CLEAN_EXPIRED_TRANSACTIONS=0 3 * * *

# Reset daily order count (daily at midnight)
CRON_RESET_DAILY_ORDER_COUNT=0 0 * * *

# Generate daily report (daily at 11:59 PM)
CRON_DAILY_REPORT=59 23 * * *

# ============================================================
# TELEGRAM BOT SETTINGS
# ============================================================

# Bot Username (tanpa @)
BOT_USERNAME=YourOTPBot

# Support Contact (untuk user bantuan)
SUPPORT_TELEGRAM=@YourSupportAccount
SUPPORT_EMAIL=support@yourdomain.com

# Bot Welcome Message
WELCOME_MESSAGE=Selamat datang di Bot Jasa OTP! 🎉\nSilakan gunakan /start untuk memulai.

# ============================================================
# LOCALIZATION
# ============================================================

# Default Language
DEFAULT_LANGUAGE=id

# Supported Languages (comma separated)
SUPPORTED_LANGUAGES=id,en

# Currency
CURRENCY=IDR
CURRENCY_SYMBOL=Rp

# ============================================================
# EXTERNAL SERVICES (Optional)
# ============================================================

# CDN URL for media files
# CDN_URL=https://cdn.yourdomain.com

# S3 or Cloud Storage (untuk menyimpan bukti pembayaran, dll)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=otp-bot-storage

# ============================================================
# END OF CONFIGURATION
# ============================================================

# CATATAN KEAMANAN:
# 1. Jangan pernah commit file .env ke Git
# 2. Gunakan password yang kuat (minimal 16 karakter)
# 3. Rotasi secret keys secara berkala
# 4. Enkripsi sensitive data sebelum disimpan ke database
# 5. Gunakan HTTPS untuk production
# 6. Enable firewall dan restrict port access
# 7. Regular security audit dan update dependencies
